#include <stdio.h>
#include <string.h>

int main()
{
    char palavraEscolhida[] = "algoritmo";
    char palavraMostrada[30];
    char letraTentada;
    int tamanhoPalavra;
    int quantidadeErros = 0;
    int letrasDescobertas = 0;
    int posicaoAtual;
    int achouLetra;

    tamanhoPalavra = strlen(palavraEscolhida);

    // Monta a palavra escondida usando o caractere _
    for (posicaoAtual = 0; posicaoAtual < tamanhoPalavra; posicaoAtual++)
    {
        palavraMostrada[posicaoAtual] = '_';
    }

    palavraMostrada[tamanhoPalavra] = '\0';

    printf("=====================================\n");
    printf("            JOGO DA FORCA            \n");
    printf("=====================================\n\n");

    printf("Descubra a palavra secreta.\n");
    printf("Limite maximo: 6 erros.\n\n");

    while (quantidadeErros < 6 && letrasDescobertas < tamanhoPalavra)
    {
        printf("Palavra atual: ");

        for (posicaoAtual = 0; posicaoAtual < tamanhoPalavra; posicaoAtual++)
        {
            printf("%c ", palavraMostrada[posicaoAtual]);
        }

        printf("\nErros cometidos: %d\n", quantidadeErros);
        printf("Digite uma letra: ");
        scanf(" %c", &letraTentada);

        achouLetra = 0;

        // Percorre a palavra verificando se a letra existe
        for (posicaoAtual = 0; posicaoAtual < tamanhoPalavra; posicaoAtual++)
        {
            if (palavraEscolhida[posicaoAtual] == letraTentada && palavraMostrada[posicaoAtual] == '_')
            {
                palavraMostrada[posicaoAtual] = letraTentada;
                letrasDescobertas++;
                achouLetra = 1;
            }
        }

        if (achouLetra == 1)
        {
            printf("\nBoa! A letra existe na palavra.\n\n");
        }
        else
        {
            quantidadeErros++;
            printf("\nEssa letra nao faz parte da palavra.\n\n");
        }
    }

    if (letrasDescobertas == tamanhoPalavra)
    {
        printf("Parabens, voce completou a palavra!\n");
        printf("Palavra correta: %s\n", palavraEscolhida);
    }
    else
    {
        printf("Fim de jogo! O limite de erros foi atingido.\n");
        printf("A palavra secreta era: %s\n", palavraEscolhida);
    }

    return 0;
}